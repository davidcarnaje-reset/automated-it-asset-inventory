# ==========================================
# Root Gitignore for My IT Asset Inventory
# Merges rules for:
# - OS & Common Editors (VS Code, Visual Studio, etc.)
# - .NET / C# (AssetInventoryAPI, AssetInventoryAgent)
# - Node.js / Next.js (asset-inventory-dashboard)
# ==========================================

# ------------------------------------------
# Operating System & IDEs
# ------------------------------------------
# OS files
.DS_Store
Thumbs.db
desktop.ini

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/gdbinit
!.vscode/containerfile

# Visual Studio / Rider / Resharper
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
.vs/

# ------------------------------------------
# .NET / C# (API & Agent)
# ------------------------------------------
# Build results (recursive for all subfolders)
bin/
obj/

# Publish output
[Pp]ublish/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Mono auto generated files
mono_crash.*

# NuGet Packages
*.nupkg
packages/

# StyleCop writing cache
StyleCop.Cache

# Backup and recovery files from Visual Studio
_ReSharper*/
*.[Cc]ach
[Dd]ebug/
[Rr]elease/

# ------------------------------------------
# Node.js / Next.js (Dashboard)
# ------------------------------------------
# Dependency directories
node_modules/
jspm_packages/

# Next.js build output
.next/
out/

# Production build output
build/

# Testing
coverage/
.nyc_output

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# Environment files (sensitive data)
.env*
*.env.local

# Vercel
.vercel

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# Misc files
*.pem

# Yarn/Pnpm package managers
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
